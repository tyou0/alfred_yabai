#!/bin/bash
set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any check failed
FAILED=0

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Get list of staged bash scripts
BASH_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.sh$' || true)

if [ -z "$BASH_FILES" ]; then
    echo -e "${GREEN}No bash scripts staged for commit.${NC}"
    exit 0
fi

# Run shellcheck if available
if command -v shellcheck &> /dev/null; then
    echo -e "${YELLOW}Running shellcheck...${NC}"
    while IFS= read -r file; do
        echo -n "  Checking $file... "
        if shellcheck "$file"; then
            echo -e "${GREEN}✓${NC}"
        else
            echo -e "${RED}✗${NC}"
            FAILED=1
        fi
    done <<< "$BASH_FILES"
else
    echo -e "${YELLOW}shellcheck not found. Install via 'brew install shellcheck'${NC}"
fi

# Run bash syntax check
echo -e "${YELLOW}Running bash syntax check...${NC}"
while IFS= read -r file; do
    echo -n "  Checking $file... "
    if bash -n "$file"; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        FAILED=1
    fi
done <<< "$BASH_FILES"

# Check for common formatting issues
echo -e "${YELLOW}Checking formatting...${NC}"
while IFS= read -r file; do
    # Check for tabs instead of spaces (macOS compatible)
    if grep -q "$(printf '\t')" "$file"; then
        echo -e "  ${RED}✗${NC} $file contains tabs (use spaces instead)"
        FAILED=1
    fi
    
    # Check for trailing whitespace (macOS compatible)
    if grep -q '[[:space:]]$' "$file"; then
        echo -e "  ${RED}✗${NC} $file contains trailing whitespace"
        FAILED=1
    fi
    
    # Check for proper shebang
    if ! head -1 "$file" | grep -q '#!/bin/bash'; then
        echo -e "  ${RED}✗${NC} $file missing or incorrect shebang (should be #!/bin/bash)"
        FAILED=1
    fi
    
    # Check for set -euo pipefail
    if ! grep -q 'set -euo pipefail' "$file"; then
        echo -e "  ${RED}✗${NC} $file missing 'set -euo pipefail' for safety"
        FAILED=1
    fi
done <<< "$BASH_FILES"

if [ $FAILED -eq 1 ]; then
    echo -e "\n${RED}❌ Pre-commit checks failed. Please fix the issues above.${NC}"
    exit 1
else
    echo -e "\n${GREEN}✅ All pre-commit checks passed!${NC}"
    exit 0
fi
